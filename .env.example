# ---------------------------------------------------------------------------
# Kàff GUI Mobile — environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` (untracked) and fill in real values.
# Only variables prefixed with EXPO_PUBLIC_ are exposed to the JS bundle.
# Anything sensitive (e.g. Sentry DSN that must stay private) belongs in EAS
# secrets instead of this file.
# ---------------------------------------------------------------------------

# API base URL (Django REST backend)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Authentication
EXPO_PUBLIC_API_TIMEOUT_MS=15000

# Feature flags
EXPO_PUBLIC_ENABLE_LOGS=true
EXPO_PUBLIC_ENABLE_DEVTOOLS=true

# Optional observability (leave empty to disable)
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_APP_ENV=development
